rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 't.m.searle@gmail.com';
    }

    // ─── Users Collection ───
    // Anyone authenticated can read user profiles (needed for leaderboard, chat display names)
    // Users can only write their own document; admins can delete any user
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    // ─── Brackets Collection ───
    // Document IDs: Entry 1 = {uid}, Entry 2+ = {uid}_{entryNum}
    // Anyone authenticated can read all brackets (needed for leaderboard scoring)
    // Users can only create/update their own brackets; admins can delete any
    function ownsBracket(bracketId) {
      return bracketId == request.auth.uid
        || bracketId.matches(request.auth.uid + '_.*');
    }

    match /brackets/{bracketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && ownsBracket(bracketId);
      allow update: if request.auth != null && ownsBracket(bracketId);
      allow delete: if request.auth != null
        && (ownsBracket(bracketId) || isAdmin());
    }

    // ─── Bracket Chat Collection ───
    // Anyone authenticated can read and create messages
    // Only the message author or an admin can delete messages
    match /bracketChat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ─── Deny everything else ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
